const generateStickers = () => {
  const categories = ['Graffiti', 'Urban', 'Anime', 'Gaming', 'Music', 'Art', 'Street', 'Cool'];
  const adjectives = ['Neon', 'Cyber', 'Urban', 'Retro', 'Epic', 'Cool', 'Fresh', 'Rad'];
  const nouns = ['Skull', 'Flame', 'Star', 'Lightning', 'Crown', 'Rocket', 'Dragon', 'Phoenix', 'Tiger', 'Wolf', 'Unicorn', 'Ghost'];
  
  return Array.from({ length: 140 }, (_, i) => ({
    id: i + 1,
    name: `${adjectives[i % adjectives.length]} ${nouns[i % nouns.length]} #${i + 1}`,
    category: categories[i % categories.length],
    price: 12,
    emoji: ['💀', '🔥', '⭐', '⚡', '👑', '🚀', '🐉', '🦅', '🌟', '🎸', '🎮', '💎', '🌈', '🍕', '🤘', '💪'][i % 16]
  }));
};

