  const addToCart = (id: number) => {
    setCart(prev => {
      const existing = prev.find(item => item.id === id);
      if (existing) {
        return prev.map(item =>
          item.id === id ? { ...item, quantity: item.quantity + 1 } : item
        );
      }
      return [...prev, { id, quantity: 1 }];
    });
    
    setAddedItems(prev => new Set([...prev, id]));
    setTimeout(() => {
      setAddedItems(prev => {
        const next = new Set(prev);
        next.delete(id);
        return next;
      });
    }, 1500);
  };

  const updateQuantity = (id: number, delta: number) => {
    setCart(prev => {
      const updated = prev.map(item => {
        if (item.id === id) {
          const newQty = item.quantity + delta;
          return newQty > 0 ? { ...item, quantity: newQty } : item;
        }
        return item;
      }).filter(item => item.quantity > 0);
      return updated;
    });
  };

  const removeFromCart = (id: number) => {
    setCart(prev => prev.filter(item => item.id !== id));
  };

  const getCartTotal = () => {
    const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
    const subtotal = cart.reduce((sum, item) => {
      const sticker = stickers.find(s => s.id === item.id);
      return sum + (sticker?.price || 0) * item.quantity;
    }, 0);
    const discount = totalItems > 20 ? subtotal * 0.1 : 0;
    return { subtotal, discount, total: subtotal - discount, totalItems };
  };

  const handlePlaceOrder = () => {
    if (orderForm.fullName && orderForm.phoneNumber && orderForm.address) {
      setOrderSubmitted(true);
      console.log('Order submitted:', { ...orderForm, items: cart, total: getCartTotal() });
    }
  };

